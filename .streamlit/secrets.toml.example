[app]
user_name = "Your Name"

[enable_banking]
app_id = "your-app-uuid"      # from https://enablebanking.com → your application

[anthropic]
api_key = "sk-ant-..."        # from https://console.anthropic.com — optional, enables AI features

[trade_republic]               # optional — remove section if not using TR
phone_no = "+4917612345678"   # your full phone number including country code
pin = "1234"                  # your 4-digit Trade Republic PIN

[email]                        # optional — remove section if not using email summaries
to = "you@example.com"
user = "you@gmail.com"
app_password = "xxxx xxxx xxxx xxxx"  # Gmail App Password (not your regular password)
                                       # Generate at myaccount.google.com → Security → App passwords
