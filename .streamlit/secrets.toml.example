[app]
user_name = "Your Name"
savings_goal = "Your savings goal, e.g. Buy a flat — target €150,000"  # optional

[email]
to = "you@example.com"
user = "you@gmail.com"
app_password = "xxxx xxxx xxxx xxxx"  # Gmail App Password (not your regular password)

[anthropic]
api_key = "sk-ant-..."  # from https://console.anthropic.com

[trade_republic]
phone_no = "+4917612345678"  # your full phone number including country code
pin = "1234"                 # your 4-digit Trade Republic PIN

[enable_banking]
app_id = "your-app-uuid"      # from https://enablebanking.com dashboard
session_id = "your-session-uuid"  # obtained by running src/finapp/banking/fetch_accounts.py

[accounts]
personal_id = "your-account-uuid"    # printed by fetch_accounts.py after OAuth
joint_eur_id = "your-account-uuid"   # joint account (EUR) — remove if not applicable
joint_gbp_id = "your-account-uuid"   # joint account (GBP) — remove if not applicable
